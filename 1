// BRAIN DUMP
function processDump() {
  const raw=document.getElementById('dumpInput').value.trim();if(!raw)return;
  raw.split('\n').filter(l=>l.trim()).forEach(line=>state.dumpItems.push({id:uid(),text:line.trim(),priority:'mid',date:activeDate}));
  save();renderDump();document.getElementById('dumpInput').value='';
  document.getElementById('dumpList').style.display='block';
}
// Global map for safe dump item id access
window._dumpMap = {};

function renderDump() {
  const show = state.dumpItems.filter(i=>(i.date||realToday())===activeDate);
  document.getElementById('dumpCount').textContent=show.length;
  const c=document.getElementById('dumpItems');
  if(!show.length){
    c.innerHTML=`<div style="padding:24px;text-align:center;color:var(--muted);font-family:'Space Mono',monospace;font-size:11px;border:1px dashed var(--border)">✓ 이 날짜에 분류된 항목이 없습니다</div>`;return;
  }
  window._dumpMap = {};
  show.forEach((item, idx) => { window._dumpMap[idx] = item.id; });
  c.innerHTML=show.map((item,idx)=>`
    <div class="dump-item">
      <div style="width:8px;height:8px;border-radius:50%;background:${item.priority==='high'?'var(--accent)':item.priority==='mid'?'var(--accent2)':'var(--muted)'};flex-shrink:0;margin-top:6px"></div>
      <div style="flex:1">
        <div class="dump-text">${escHtml(item.text)}</div>
        <div class="dump-actions">
          <select onchange="setPriority(window._dumpMap[${idx}],this.value)" style="font-size:9px;padding:4px 8px;width:auto;font-family:'Space Mono',monospace;letter-spacing:1px">
            <option value="high" ${item.priority==='high'?'selected':''}>● HIGH</option>
            <option value="mid"  ${item.priority==='mid' ?'selected':''}>● MID</option>
            <option value="low"  ${item.priority==='low' ?'selected':''}>● LOW</option>
          </select>
          <button class="btn btn-xs btn-primary"   onclick="dumpToBig3(window._dumpMap[${idx}])">→ BIG 3</button>
          <button class="btn btn-xs btn-secondary" onclick="dumpToBacklog(window._dumpMap[${idx}],'later')">→ 나중에</button>
          <button class="btn btn-xs btn-secondary" onclick="dumpToBacklog(window._dumpMap[${idx}],'someday')">→ 언젠가</button>
          <button class="btn btn-xs btn-danger"    onclick="removeItem(window._dumpMap[${idx}])">✕</button>
        </div>
      </div>
    </div>`).join('');
}
function setPriority(id,val){const i=state.dumpItems.find(i=>i.id===id);if(i){i.priority=val;save();renderDump();}}
function removeItem(id){state.dumpItems=state.dumpItems.filter(i=>i.id!==id);save();renderDump();}
function dumpToBig3(id){
  const item=state.dumpItems.find(i=>i.id===id);if(!item)return;
  if(state.big3.filter(i=>i.date===activeDate).length>=3){alert('Big 3는 하루 최대 3개입니다!');return;}
  state.big3.push({id:uid(),text:item.text,done:false,date:activeDate,subtasks:[]});
  state.dumpItems=state.dumpItems.filter(i=>i.id!==id);save();renderDump();
}
function dumpToBacklog(id,category){
  const item=state.dumpItems.find(i=>i.id===id);if(!item)return;
  state.backlog.push({id:uid(),text:item.text,category,note:'',date:activeDate});
  state.dumpItems=state.dumpItems.filter(i=>i.id!==id);save();renderDump();
}
function clearDump(){
  if(confirm('이 날짜의 Brain Dump 항목을 모두 삭제하시겠습니까?')){
    state.dumpItems=state.dumpItems.filter(i=>(i.date||realToday())!==activeDate);
    save();renderDump();document.getElementById('dumpList').style.display='none';
  }
}

// BIG 3
function renderBig3(){
  const items=state.big3.filter(i=>i.date===activeDate);
  const c=document.getElementById('big3Container');
  const isFuture = dateDiffDays(realToday(), activeDate) > 0;
  if(!items.length){
    c.innerHTML=`<div style="padding:40px;text-align:center;color:var(--muted);font-family:'Space Mono',monospace;font-size:12px;letter-spacing:2px;border:1px dashed var(--border)">${isFuture?'내일의':'이 날의'} Big 3를 미리 설정하세요<br><span style="font-size:10px;display:block;margin-top:8px">Brain Dump에서 분류하거나 직접 입력하세요</span></div>`;
    updateStats([]);return;
  }
  c.innerHTML=items.map((item,i)=>{
    const subs=item.subtasks||[];
    const doneSubs=subs.filter(s=>s.done).length;
    const pct=subs.length?Math.round(doneSubs/subs.length*100):(item.done?100:0);
    const allDone=item.done||(subs.length>0&&doneSubs===subs.length);
    return `<div class="big3-item ${allDone?'all-done':''}">
      <div class="big3-top">
        <div class="big3-num">${String(i+1).padStart(2,'0')}</div>
        <div class="big3-content">
          <div class="big3-label">TODAY'S PRIORITY ${i+1}</div>
          <div class="big3-text">${escHtml(item.text)}</div>
          ${subs.length===0?`<div class="subtask-hint">💡 첫 번째 물리적 행동은 무엇인가요?<br>동사로 시작하는 서브태스크로 쪼개세요<br><span style="color:var(--accent)">"촬영 장소 도착" → "카메라 세팅" → "10분 영상 녹화"</span></div>`:''}
          <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
          <div class="progress-text">${pct}% 완료${subs.length?` (${doneSubs}/${subs.length} 서브태스크)`:''}</div>
          ${subs.length>0?`<div class="subtask-list">${subs.map(s=>`
            <div class="subtask-item">
              <div class="sub-check ${s.done?'done':''}" onclick="toggleSubtask('${item.id}','${s.id}')"></div>
              <span class="sub-text ${s.done?'done':''}">${escHtml(s.text)}</span>
              <button class="btn btn-xs btn-danger" style="opacity:.4;padding:3px 8px" onclick="removeSubtask('${item.id}','${s.id}')">✕</button>
            </div>`).join('')}</div>`:''}
          <div class="subtask-add">
            <input type="text" id="si-${item.id}" placeholder="서브태스크 추가 (Enter로 저장)" onkeydown="if(event.key==='Enter')addSubtask('${item.id}')">
            <button class="btn btn-xs btn-primary" onclick="addSubtask('${item.id}')">ADD</button>
          </div>
        </div>
        <div class="big3-actions">
          <div class="check-btn ${allDone?'checked':''}" onclick="toggleBig3('${item.id}')"></div>
          <button class="btn btn-sm" style="background:var(--accent);color:#000;font-size:9px" onclick="startFocus('${escHtml(item.text)}')">▶ FOCUS</button>
          <button class="btn btn-sm btn-secondary" style="font-size:9px;color:#6699aa;border-color:#6699aa44" onclick="big3ToBacklog('${item.id}')" title="Backlog으로 이동">→ BL</button>
          <button class="btn btn-sm btn-danger" onclick="removeBig3('${item.id}')">✕</button>
        </div>
      </div>
    </div>`;
  }).join('');
  updateStats(items);
}
function updateStats(items){
  const done=items.filter(i=>{const s=i.subtasks||[];return i.done||(s.length>0&&s.every(x=>x.done));}).length;
  document.getElementById('s-done').textContent=done;
  document.getElementById('s-rate').textContent=items.length?Math.round(done/items.length*100)+'%':'0%';
  document.getElementById('s-streak').textContent=state.streak;
}
function addBig3(){
  const input=document.getElementById('big3Input');const text=input.value.trim();if(!text)return;
  if(state.big3.filter(i=>i.date===activeDate).length>=3){alert('Big 3는 하루 최대 3개입니다!');return;}
  state.big3.push({id:uid(),text,done:false,date:activeDate,subtasks:[]});
  input.value='';save();renderBig3();
}
function toggleBig3(id){
  const item=state.big3.find(i=>i.id===id);if(!item)return;
  item.done=!item.done;
  if(item.done&&item.subtasks)item.subtasks.forEach(s=>s.done=true);
  save();renderBig3();
  const td=state.big3.filter(i=>i.date===activeDate);
  if(activeDate===realToday()&&td.length>0&&td.every(i=>i.done||(i.subtasks&&i.subtasks.length>0&&i.subtasks.every(s=>s.done)))){
    state.streak++;save();setTimeout(()=>alert('🎯 Big 3 완료! 스트릭 '+state.streak+'일!'),100);
  }
}
function removeBig3(id){state.big3=state.big3.filter(i=>i.id!==id);save();renderBig3();}
function big3ToBacklog(id){
  const item=state.big3.find(i=>i.id===id);if(!item)return;
  // Open a small modal to choose category
  const choice=window._b3BacklogChoice=item.id;
  document.getElementById('b3BacklogText').textContent=item.text;
  document.getElementById('b3BacklogModal').classList.add('open');
}
function confirmBig3ToBacklog(category){
  const id=window._b3BacklogChoice;
  const item=state.big3.find(i=>i.id===id);if(!item)return;
  state.backlog.push({id:uid(),text:item.text,category,note:'',date:activeDate});
  state.big3=state.big3.filter(i=>i.id!==id);
  window._b3BacklogChoice=null;
  save();closeModal('b3BacklogModal');renderBig3();
}
function addSubtask(big3Id){
  const input=document.getElementById('si-'+big3Id);const text=input.value.trim();if(!text)return;
  const item=state.big3.find(i=>i.id===big3Id);if(!item)return;
  if(!item.subtasks)item.subtasks=[];
  item.subtasks.push({id:uid(),text,done:false});
  input.value='';save();renderBig3();
  setTimeout(()=>{const el=document.getElementById('si-'+big3Id);if(el)el.focus();},50);
}
function toggleSubtask(big3Id,subId){
  const item=state.big3.find(i=>i.id===big3Id);if(!item||!item.subtasks)return;
  const sub=item.subtasks.find(s=>s.id===subId);if(sub){sub.done=!sub.done;save();renderBig3();}
}
function removeSubtask(big3Id,subId){
  const item=state.big3.find(i=>i.id===big3Id);if(!item)return;
  item.subtasks=item.subtasks.filter(s=>s.id!==subId);save();renderBig3();
}

// BACKLOG
let currentFilter='all';
const CAT={later:{label:'나중에',color:'#6699aa'},someday:{label:'언젠가',color:'#aaa866'},idea:{label:'아이디어',color:'#bb8866'}};
function renderBacklog(filter){
  currentFilter=filter;
  const items=filter==='all'?state.backlog:state.backlog.filter(i=>i.category===filter);
  const c=document.getElementById('backlogList');
  if(!items.length){
    c.innerHTML=`<div style="padding:32px;text-align:center;color:var(--muted);font-family:'Space Mono',monospace;font-size:11px;border:1px dashed var(--border)">항목이 없습니다<br><span style="font-size:9px;display:block;margin-top:6px">Brain Dump에서 분류하거나 + ADD로 추가하세요</span></div>`;return;
  }
  c.innerHTML=items.map(item=>{
    const cat=CAT[item.category]||{label:item.category,color:'var(--muted)'};
    return `<div class="backlog-item">
      <span class="cat-badge" style="color:${cat.color};border-color:${cat.color}66">${cat.label}</span>
      <div style="flex:1">
        <div style="font-size:14px;margin-bottom:${item.note?'4px':'0'}">${escHtml(item.text)}</div>
        ${item.note?`<div style="font-size:12px;color:var(--muted)">${escHtml(item.note)}</div>`:''}
      </div>
      <button class="btn btn-xs btn-primary" onclick="backlogToBig3('${item.id}')" title="오늘 Big 3로 올리기">→ B3</button>
      <button class="btn btn-xs btn-danger"  onclick="removeBacklog('${item.id}')">✕</button>
    </div>`;
  }).join('');
}
function filterBacklog(filter,btn){
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));btn.classList.add('active');renderBacklog(filter);
}
function backlogToBig3(id){
  const item=state.backlog.find(i=>i.id===id);if(!item)return;
  if(state.big3.filter(i=>i.date===activeDate).length>=3){alert('Big 3는 하루 최대 3개입니다!');return;}
  state.big3.push({id:uid(),text:item.text,done:false,date:activeDate,subtasks:[]});
  state.backlog=state.backlog.filter(i=>i.id!==id);
  save();renderBacklog(currentFilter);
  alert('Big 3에 추가됐습니다! Big 3 탭에서 서브태스크를 설정하세요.');
}
function removeBacklog(id){state.backlog=state.backlog.filter(i=>i.id!==id);save();renderBacklog(currentFilter);}
function openAddBacklog(){document.getElementById('backlogModal').classList.add('open');}
function saveBacklogItem(){
  const text=document.getElementById('backlogTask').value.trim();if(!text)return;
  state.backlog.push({id:uid(),text,category:document.getElementById('backlogCategory').value,note:document.getElementById('backlogNote').value.trim(),date:activeDate});
  document.getElementById('backlogTask').value='';document.getElementById('backlogNote').value='';
  save();closeModal('backlogModal');renderBacklog(currentFilter);
}

// TIME BOXING
let editingBlockId = null;
function initBlockModal(){
  const sel=document.getElementById('blockHour');
  for(let h=5;h<=23;h++)sel.innerHTML+=`<option value="${String(h).padStart(2,'0')}">${String(h).padStart(2,'0')}</option>`;
}
function openAddBlock(){
  editingBlockId = null;
  document.getElementById('blockModalTitle').textContent = 'TIME BLOCK';
  document.getElementById('blockSaveBtn').textContent = '저장';
  document.getElementById('blockTask').value = '';
  // reset hour/min to current time
  const now = new Date();
  const h = document.getElementById('blockHour');
  const m = document.getElementById('blockMin');
  const curH = String(now.getHours()).padStart(2,'0');
  for(let i=0;i<h.options.length;i++) if(h.options[i].value===curH){h.selectedIndex=i;break;}
  m.value = '00';
  document.getElementById('blockModal').classList.add('open');
  switchImportTab('big3');
}

function openEditBlock(id) {
  const b = state.blocks.find(b=>b.id===id); if(!b) return;
  editingBlockId = id;
  document.getElementById('blockModalTitle').textContent = 'EDIT BLOCK';
  document.getElementById('blockSaveBtn').textContent = '수정 완료';
  // hide import tabs section
  document.getElementById('importTabsSection').style.display = 'none';
  document.getElementById('importDivider').style.display = 'none';
  // fill fields
  const h = document.getElementById('blockHour');
  const hVal = b.time.split(':')[0];
  for(let i=0;i<h.options.length;i++) if(h.options[i].value===hVal){h.selectedIndex=i;break;}
  document.getElementById('blockMin').value = b.time.split(':')[1];
  document.getElementById('blockTask').value = b.task;
  document.getElementById('blockType').value = b.type;
  document.getElementById('blockDuration').value = b.duration;
  document.getElementById('blockModal').classList.add('open');
}
function switchImportTab(tab){
  ['big3','backlog','dump'].forEach(t=>{
    document.getElementById('itab-'+t).classList.toggle('active',t===tab);
    document.getElementById('ilist-'+t).style.display=t===tab?'block':'none';
  });
  if(tab==='big3')   renderIBig3();
  if(tab==='backlog')renderIBacklog();
  if(tab==='dump')   renderIDump();
}
function iRow(text,type){
  const safe=text.replace(/\\/g,'\\\\').replace(/'/g,"\\'");
  return `<div onclick="importTask('${safe}','${type}')" style="display:flex;align-items:center;gap:10px;padding:9px 14px;border:1px solid var(--border);margin-bottom:5px;cursor:pointer;background:var(--surface2)" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
    <span style="flex:1;font-size:13px">${escHtml(text)}</span>
    <span style="font-size:9px;color:var(--accent);border:1px solid var(--accent);padding:2px 6px">+ IMPORT</span>
  </div>`;
}
function emptyI(msg){return `<div style="padding:12px;font-family:'Space Mono',monospace;font-size:10px;color:var(--muted);border:1px dashed var(--border);text-align:center">${msg}</div>`;}
function renderIBig3(){
  const items=state.big3.filter(i=>i.date===activeDate);
  document.getElementById('ilist-big3').innerHTML=items.length?`<div style="max-height:160px;overflow-y:auto">${items.map((it,idx)=>iRow(`${idx+1}. ${it.text}`,'deep')).join('')}</div>`:emptyI('이 날의 Big 3가 없습니다');
}
function renderIBacklog(){
  document.getElementById('ilist-backlog').innerHTML=state.backlog.length?`<div style="max-height:160px;overflow-y:auto">${state.backlog.map(i=>iRow(i.text,'admin')).join('')}</div>`:emptyI('Backlog 항목이 없습니다');
}
function renderIDump(){
  const sorted=[...state.dumpItems].sort((a,b)=>({high:0,mid:1,low:2}[a.priority]||2)-({high:0,mid:1,low:2}[b.priority]||2));
  document.getElementById('ilist-dump').innerHTML=sorted.length?`<div style="max-height:160px;overflow-y:auto">${sorted.map(i=>iRow(i.text,i.priority==='high'?'deep':'admin')).join('')}</div>`:emptyI('Brain Dump 항목이 없습니다');
}
function importTask(text,type){
  document.getElementById('blockTask').value=text;document.getElementById('blockType').value=type;
  const inp=document.getElementById('blockTask');inp.style.borderColor='var(--accent)';setTimeout(()=>{inp.style.borderColor='var(--border)';},900);
}
function saveBlock(){
  const task=document.getElementById('blockTask').value.trim();if(!task)return;
  const time=`${document.getElementById('blockHour').value}:${document.getElementById('blockMin').value}`;
  const type=document.getElementById('blockType').value;
  const duration=parseInt(document.getElementById('blockDuration').value);
  if(editingBlockId) {
    const b=state.blocks.find(b=>b.id===editingBlockId);
    if(b){b.task=task;b.time=time;b.type=type;b.duration=duration;}
    editingBlockId=null;
  } else {
    state.blocks.push({id:uid(),time,task,type,duration,done:false,date:activeDate});
  }
  document.getElementById('blockTask').value='';
  document.getElementById('importTabsSection').style.display='flex';
  document.getElementById('importDivider').style.display='block';
  save();closeModal('blockModal');renderTimeGrid();
}
function renderTimeGrid(){
  const grid=document.getElementById('timeGrid');
  const tb=state.blocks.filter(b=>b.date===activeDate).sort((a,b)=>a.time.localeCompare(b.time));
  if(!tb.length){
    grid.innerHTML=`<div style="grid-column:1/-1;padding:40px;text-align:center;color:var(--muted);font-family:'Space Mono',monospace;font-size:11px;border:1px dashed var(--border)">+ 버튼으로 시간 블록을 추가하세요</div>`;
  } else {
    grid.innerHTML=tb.map(b=>`
      <div class="time-label">${b.time}</div>
      <div class="time-block ${b.type} ${b.done?'done-block':''}" onclick="toggleBlock('${b.id}')">
        <span>${escHtml(b.task)} <span style="color:var(--muted);font-size:11px">(${b.duration}분)</span></span>
        <div style="display:flex;align-items:center;gap:8px">
          <span class="block-tag tag-${b.type}">${b.type.toUpperCase()}</span>
          <button class="btn btn-sm" style="background:transparent;border:1px solid var(--border);color:var(--muted);font-size:9px;padding:5px 8px" onclick="event.stopPropagation();openEditBlock('${b.id}')" title="편집">✎</button>
          <button class="btn btn-sm" style="background:var(--accent);color:#000;font-size:9px;padding:5px 8px" onclick="event.stopPropagation();startFocus('${escHtml(b.task)}',${b.duration})">▶</button>
          <button class="btn btn-sm btn-danger" onclick="event.stopPropagation();removeBlock('${b.id}')" style="padding:5px 8px">✕</button>
        </div>
      </div>`).join('');
  }
  const tc={};state.typeGuide.forEach(t=>tc[t.key]=0);
  tb.forEach(b=>tc[b.type]=(tc[b.type]||0)+b.duration);
  const tot=Object.values(tc).reduce((a,b)=>a+b,0)||1;
  document.getElementById('progressStats').innerHTML=Object.entries(tc).map(([t,m])=>`<div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border)"><span style="text-transform:uppercase">${t}</span><span>${m}분 (${Math.round(m/tot*100)}%)</span></div>`).join('');
}
function toggleBlock(id){const b=state.blocks.find(b=>b.id===id);if(b){b.done=!b.done;save();renderTimeGrid();}}
function removeBlock(id){state.blocks=state.blocks.filter(b=>b.id!==id);save();renderTimeGrid();}

// TYPE GUIDE
