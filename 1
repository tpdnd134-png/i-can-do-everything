  const c=document.getElementById('typeGuideDisplay');if(!c)return;
  c.innerHTML=state.typeGuide.map(t=>`
    <div style="padding:12px 16px;border:1px solid ${t.borderColor};border-left:4px solid ${t.borderColor};background:${t.bg};display:flex;align-items:center;justify-content:space-between">
