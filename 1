      <div style="display:grid;grid-template-columns:1fr 2fr;gap:10px">
        <div><div style="font-family:'Space Mono',monospace;font-size:9px;color:var(--muted);margin-bottom:6px">이모지 + 이름</div>
          <div style="display:flex;gap:6px"><input type="text" id="tge-${i}" value="${t.emoji}" style="width:50px;text-align:center;font-size:16px;padding:8px"><input type="text" id="tgn-${i}" value="${t.name}" style="flex:1"></div>
        </div>
        <div><div style="font-family:'Space Mono',monospace;font-size:9px;color:var(--muted);margin-bottom:6px">설명</div><input type="text" id="tgd-${i}" value="${t.desc}"></div>
      </div>
    </div>`).join('');
  document.getElementById('typeGuideModal').classList.add('open');
}
function saveTypeGuide(){
  state.typeGuide.forEach((t,i)=>{state.typeGuide[i]={...t,emoji:document.getElementById('tge-'+i).value.trim()||t.emoji,name:document.getElementById('tgn-'+i).value.trim()||t.name,desc:document.getElementById('tgd-'+i).value.trim()};});
  save();renderTypeGuideDisplay();populateBlockTypeSelect();closeModal('typeGuideModal');
}

// FOCUS
function startFocus(task,minutes=25){
  state.focusSeconds=minutes*60;document.getElementById('focusTask').textContent=task;document.getElementById('focusBanner').style.display='flex';
  clearInterval(state.focusInterval);
  state.focusInterval=setInterval(()=>{
    state.focusSeconds--;
    const m=Math.floor(state.focusSeconds/60),s=state.focusSeconds%60;
    document.getElementById('focusTimer').textContent=`${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    if(state.focusSeconds<=0){clearInterval(state.focusInterval);alert('✅ 세션 완료! "'+task+'"');stopFocus();}
  },1000);
}
function stopFocus(){clearInterval(state.focusInterval);document.getElementById('focusBanner').style.display='none';}

// REVIEW
function saveReview(){
  const win=document.getElementById('reviewWin').value.trim(),miss=document.getElementById('reviewMiss').value.trim(),improve=document.getElementById('reviewImprove').value.trim();
  if(!win&&!miss&&!improve)return;
  state.reviews.unshift({date:activeDate,win,miss,improve,ts:new Date().toLocaleString('ko-KR')});
  ['reviewWin','reviewMiss','reviewImprove'].forEach(id=>document.getElementById(id).value='');
  save();renderReviews();alert('리뷰 저장 완료!');
}
function renderReviews(){
  const c=document.getElementById('reviewHistory');
  if(!state.reviews.length){c.innerHTML=`<div style="padding:24px;text-align:center;color:var(--muted);font-family:'Space Mono',monospace;font-size:11px;border:1px dashed var(--border)">아직 리뷰가 없습니다</div>`;return;}
  c.innerHTML=state.reviews.map(r=>`<div class="card" style="margin-bottom:12px"><div style="display:flex;justify-content:space-between;margin-bottom:16px"><span style="font-family:'Space Mono',monospace;font-size:10px;color:var(--accent)">${r.date}</span><span style="font-family:'Space Mono',monospace;font-size:9px;color:var(--muted)">${r.ts||''}</span></div>${r.win?`<div style="margin-bottom:10px"><div style="font-family:'Space Mono',monospace;font-size:9px;color:var(--accent3);margin-bottom:4px">WIN</div><div style="font-size:13px">${escHtml(r.win)}</div></div>`:''} ${r.miss?`<div style="margin-bottom:10px"><div style="font-family:'Space Mono',monospace;font-size:9px;color:var(--accent2);margin-bottom:4px">MISS</div><div style="font-size:13px">${escHtml(r.miss)}</div></div>`:''} ${r.improve?`<div><div style="font-family:'Space Mono',monospace;font-size:9px;color:var(--muted);margin-bottom:4px">TOMORROW</div><div style="font-size:13px">${escHtml(r.improve)}</div></div>`:''}</div>`).join('');
}

// UTILS
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2);}
function escHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
function closeModal(id){
  document.getElementById(id).classList.remove('open');
  if(id==='blockModal'){
    editingBlockId=null;
    const ts=document.getElementById('importTabsSection');
    const div=document.getElementById('importDivider');
    if(ts)ts.style.display='flex';
    if(div)div.style.display='block';
    document.getElementById('blockModalTitle').textContent='TIME BLOCK';
    document.getElementById('blockSaveBtn').textContent='저장';
  }
}

// INIT — wrapped so Firebase can call after load
function initApp() {
  initBlockModal();
  renderTypeGuideDisplay();
  populateBlockTypeSelect();
  updateDateBar();
  if(state.dumpItems.filter(i=>(i.date||realToday())===activeDate).length>0){
    document.getElementById('dumpList').style.display='block';
  }
  renderDump();
  renderBig3();
}

// Close calendar when clicking outside
document.addEventListener('click',e=>{
  const pop=document.getElementById('calPopup');
  const btn=document.getElementById('dateDisplay');
  if(pop.style.display==='block'&&!pop.contains(e.target)&&e.target!==btn){pop.style.display='none';}
});

// Start: load from Firebase
loadData();
</script>
</body>
