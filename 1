<script>
const DEFAULT_TYPES = [
  {key:'deep',emoji:'🔴',name:'딥 워크',desc:'핵심 목표 집중',borderColor:'#3a4a00',bg:'#1a1f00',tagClass:'tag-deep'},
  {key:'admin',emoji:'🔵',name:'행정/소통',desc:'이메일, 회의, 소통',borderColor:'#0a3333',bg:'#0d1a1a',tagClass:'tag-admin'},
  {key:'personal',emoji:'🟣',name:'개인/재충전',desc:'운동, 식사, 휴식',borderColor:'#330033',bg:'#1a0d1a',tagClass:'tag-personal'},
  {key:'buffer',emoji:'🟡',name:'버퍼/전환',desc:'이동, 준비, 전환 시간',borderColor:'#332000',bg:'#1a1000',tagClass:'tag-buffer'},
];

// ===== FIREBASE SETUP =====
const firebaseConfig = {
  apiKey: "AIzaSyD-Cdefig4oylG2t7lcWkbRZL_wUks109E",
  authDomain: "i-can-do-everything-9b73a.firebaseapp.com",
  projectId: "i-can-do-everything-9b73a",
  storageBucket: "i-can-do-everything-9b73a.firebasestorage.app",
  messagingSenderId: "353761374764",
  appId: "1:353761374764:web:5004c7c80416f323d95789",
  databaseURL: "https://i-can-do-everything-9b73a-default-rtdb.firebaseio.com"
};
firebase.initializeApp(firebaseConfig);
const db = firebase.database();
const DB_KEY = 'execsys/v1'; // root path in Firebase

const state = {
  dumpItems: [],
  big3:      [],
  backlog:   [],
  blocks:    [],
  reviews:   [],
  typeGuide: DEFAULT_TYPES,
  streak:    0,
  focusInterval:null, focusSeconds:0
};

// Sync status indicator
let syncTimeout = null;
function showSync(status) {
  const el = document.getElementById('syncStatus');
  if(!el) return;
  el.textContent = status === 'saving' ? '⟳ 저장 중...' : status === 'ok' ? '✓ 동기화됨' : '✕ 오프라인';
  el.style.color = status === 'saving' ? 'var(--muted)' : status === 'ok' ? 'var(--accent3)' : 'var(--danger)';
}

// Save to Firebase + localStorage (localStorage as offline fallback)
function save() {
  // Always save to localStorage as fallback
  ['dumpItems','big3','backlog','blocks','reviews','typeGuide'].forEach(k=>localStorage.setItem(k,JSON.stringify(state[k])));
  localStorage.setItem('streak', state.streak);

  // Save to Firebase (debounced 800ms)
  clearTimeout(syncTimeout);
  showSync('saving');
  syncTimeout = setTimeout(() => {
    const payload = {
      dumpItems: state.dumpItems,
      big3:      state.big3,
      backlog:   state.backlog,
      blocks:    state.blocks,
      reviews:   state.reviews,
      typeGuide: state.typeGuide,
      streak:    state.streak,
      updatedAt: Date.now()
    };
    db.ref(DB_KEY).set(payload)
      .then(() => showSync('ok'))
      .catch(() => showSync('offline'));
  }, 800);
}

// Load from Firebase on startup, fallback to localStorage
function loadData() {
  showSync('saving');
  // Animate loading bar
  let pct = 0;
  const bar = document.getElementById('loadingBar');
  const barAnim = setInterval(() => { pct = Math.min(pct + 8, 85); if(bar) bar.style.width = pct + '%'; if(pct>=85) clearInterval(barAnim); }, 80);
  db.ref(DB_KEY).once('value')
    .then(snapshot => {
      const data = snapshot.val();
      if(data) {
        state.dumpItems = data.dumpItems || [];
        state.big3      = data.big3      || [];
        state.backlog   = data.backlog   || [];
        state.blocks    = data.blocks    || [];
        state.reviews   = data.reviews   || [];
        state.typeGuide = data.typeGuide || DEFAULT_TYPES;
        state.streak    = data.streak    || 0;
        // Also update localStorage
        ['dumpItems','big3','backlog','blocks','reviews','typeGuide'].forEach(k=>localStorage.setItem(k,JSON.stringify(state[k])));
        localStorage.setItem('streak', state.streak);
      } else {
        // No Firebase data yet — load from localStorage
        state.dumpItems = JSON.parse(localStorage.getItem('dumpItems')||'[]');
        state.big3      = JSON.parse(localStorage.getItem('big3')||'[]');
        state.backlog   = JSON.parse(localStorage.getItem('backlog')||'[]');
        state.blocks    = JSON.parse(localStorage.getItem('blocks')||'[]');
        state.reviews   = JSON.parse(localStorage.getItem('reviews')||'[]');
        state.typeGuide = JSON.parse(localStorage.getItem('typeGuide')||'null')||DEFAULT_TYPES;
        state.streak    = parseInt(localStorage.getItem('streak')||'0');
        // If we have localStorage data, push it up to Firebase
        if(state.dumpItems.length||state.big3.length||state.blocks.length) save();
      }
      showSync('ok');
      // Animate loading bar then hide overlay
      const bar = document.getElementById('loadingBar');
      if(bar) bar.style.width = '100%';
      setTimeout(() => {
        const overlay = document.getElementById('loadingOverlay');
        if(overlay) overlay.style.display = 'none';
      }, 400);
      initApp();
    })
    .catch(() => {
      // Offline - use localStorage
      showSync('offline');
      // Hide overlay even on offline
      const overlay = document.getElementById('loadingOverlay');
      if(overlay) { overlay.querySelector('div:nth-child(2)').textContent = '오프라인 모드'; setTimeout(()=>overlay.style.display='none', 800); }
      state.dumpItems = JSON.parse(localStorage.getItem('dumpItems')||'[]');
      state.big3      = JSON.parse(localStorage.getItem('big3')||'[]');
      state.backlog   = JSON.parse(localStorage.getItem('backlog')||'[]');
      state.blocks    = JSON.parse(localStorage.getItem('blocks')||'[]');
      state.reviews   = JSON.parse(localStorage.getItem('reviews')||'[]');
      state.typeGuide = JSON.parse(localStorage.getItem('typeGuide')||'null')||DEFAULT_TYPES;
      state.streak    = parseInt(localStorage.getItem('streak')||'0');
      initApp();
    });
}

// Real-time listener - updates UI when another device saves
db.ref(DB_KEY).on('value', snapshot => {
  const data = snapshot.val();
  if(!data) return;
  // Only update if remote is newer
  if(data.updatedAt && data.updatedAt > (state._lastSaved||0)) {
    state.dumpItems = data.dumpItems || state.dumpItems;
    state.big3      = data.big3      || state.big3;
    state.backlog   = data.backlog   || state.backlog;
    state.blocks    = data.blocks    || state.blocks;
    state.reviews   = data.reviews   || state.reviews;
    state.streak    = data.streak    || state.streak;
    state._lastSaved = data.updatedAt;
    showSync('ok');
    renderCurrentTab();
    renderCal && renderCal();
  }
});

// ===== DATE SYSTEM =====
let activeDate = realToday(); // yyyy-mm-dd string

function realToday() {
  return new Date().toISOString().split('T')[0];
}
function today() {
  return activeDate; // all render functions use this
}
function formatDateDisplay(d) {
  const parts = d.split('-');
  const dt = new Date(parseInt(parts[0]), parseInt(parts[1])-1, parseInt(parts[2]));
  const days = ['일','월','화','수','목','금','토'];
  const dayName = days[dt.getDay()];
  const rt = realToday();
  const diff = dateDiffDays(rt, d);
  let label = '';
  if(diff === 0) label = 'TODAY';
  else if(diff === 1) label = '내일';
  else if(diff === -1) label = '어제';
  else if(diff > 1) label = `+${diff}일 후`;
  else label = `${Math.abs(diff)}일 전`;
  return `${parts[0]}.${parts[1]}.${parts[2]} (${dayName}) — ${label}`;
}
function dateDiffDays(from, to) {
  const a = new Date(from), b = new Date(to);
  return Math.round((b - a) / 86400000);
}
function shiftDate(delta) {
  const parts = activeDate.split('-');
  const dt = new Date(parseInt(parts[0]), parseInt(parts[1])-1, parseInt(parts[2]));
  dt.setDate(dt.getDate() + delta);
  activeDate = dt.toISOString().split('T')[0];
  updateDateBar();
  renderCurrentTab();
}
// ===== CALENDAR =====
let calViewYear, calViewMonth; // currently displayed month

function getDatesWithData() {
  const set = new Set();
  [...state.big3, ...state.blocks, ...state.reviews].forEach(i => { if(i.date) set.add(i.date); });
  state.dumpItems.forEach(i => { if(i.date) set.add(i.date); });
  return set;
}

function toggleCal() {
  const pop = document.getElementById('calPopup');
  const visible = pop.style.display === 'block';
  if(!visible) {
    const parts = activeDate.split('-');
    calViewYear = parseInt(parts[0]);
    calViewMonth = parseInt(parts[1]) - 1; // 0-indexed
    renderCal();
    pop.style.display = 'block';
  } else {
    pop.style.display = 'none';
  }
}

function calShiftMonth(delta) {
  calViewMonth += delta;
  if(calViewMonth < 0) { calViewMonth = 11; calViewYear--; }
  if(calViewMonth > 11) { calViewMonth = 0; calViewYear++; }
  renderCal();
}

function renderCal() {
  const MONTHS = ['JANUARY','FEBRUARY','MARCH','APRIL','MAY','JUNE','JULY','AUGUST','SEPTEMBER','OCTOBER','NOVEMBER','DECEMBER'];
  document.getElementById('calMonthLabel').textContent = MONTHS[calViewMonth] + ' ' + calViewYear;

  const withData = getDatesWithData();
  const rt = realToday();
  const grid = document.getElementById('calGrid');

  // Day labels
  const dayLabels = ['일','월','화','수','목','금','토'];
  let html = dayLabels.map(d => `<div class="cal-day-label">${d}</div>`).join('');

  // First day of month, last day
  const firstDay = new Date(calViewYear, calViewMonth, 1).getDay(); // 0=Sun
  const lastDate = new Date(calViewYear, calViewMonth + 1, 0).getDate();

  // Prev month padding
  const prevLastDate = new Date(calViewYear, calViewMonth, 0).getDate();
  for(let i = firstDay - 1; i >= 0; i--) {
    const d = prevLastDate - i;
    const m = calViewMonth === 0 ? 12 : calViewMonth;
    const y = calViewMonth === 0 ? calViewYear - 1 : calViewYear;
    const dateStr = `${y}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    html += calCell(d, dateStr, 'other-month', withData, rt);
  }

  // Current month
  for(let d = 1; d <= lastDate; d++) {
    const dateStr = `${calViewYear}-${String(calViewMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const dow = new Date(calViewYear, calViewMonth, d).getDay();
    let extra = dow === 0 ? 'sun' : dow === 6 ? 'sat' : '';
    html += calCell(d, dateStr, extra, withData, rt);
  }

  // Next month padding (fill to 6 rows = 42 cells)
  const total = firstDay + lastDate;
  const nextCells = total % 7 === 0 ? 0 : 7 - (total % 7);
  for(let d = 1; d <= nextCells; d++) {
    const m = calViewMonth === 11 ? 1 : calViewMonth + 2;
    const y = calViewMonth === 11 ? calViewYear + 1 : calViewYear;
    const dateStr = `${y}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    html += calCell(d, dateStr, 'other-month', withData, rt);
  }

  grid.innerHTML = html;
}

function calCell(d, dateStr, extra, withData, rt) {
  let cls = 'cal-cell';
  if(extra) cls += ' ' + extra;
  if(dateStr === rt) cls += ' today-cell';
  if(dateStr === activeDate) cls += ' selected-cell';
  if(withData.has(dateStr)) cls += ' has-data';
  return `<div class="${cls}" onclick="selectCalDate('${dateStr}')">${d}</div>`;
}

function selectCalDate(dateStr) {
  activeDate = dateStr;
  document.getElementById('calPopup').style.display = 'none';
  updateDateBar();
  renderCurrentTab();
}

function goToday() {
  activeDate = realToday();
  document.getElementById('calPopup').style.display = 'none';
  updateDateBar();
  renderCurrentTab();
}
function updateDateBar() {
  const rt = realToday();
  const diff = dateDiffDays(rt, activeDate);
  const display = document.getElementById('dateDisplay');
  display.textContent = formatDateDisplay(activeDate);
  display.className = 'date-display' + (diff > 0 ? ' future' : diff < 0 ? ' past' : '');

  const banner = document.getElementById('notTodayBanner');
  if(diff === 0) {
    banner.style.display = 'none';
  } else {
    banner.style.display = 'block';
    if(diff > 0) {
      banner.className = 'not-today-banner future';
      banner.textContent = `📅 ${activeDate} 계획 중 — 미래 날짜입니다. 오늘로 돌아가려면 날짜를 클릭하세요.`;
    } else {
      banner.className = 'not-today-banner past';
      banner.textContent = `📋 ${activeDate} 기록 열람 중 — 과거 날짜입니다.`;
    }
  }
}

let activeTab = 'brain';
const TABS=['brain','big3','backlog','timebox','review'];
function switchTab(tab) {
  activeTab = tab;
  document.querySelectorAll('.tab').forEach((t,i)=>t.classList.toggle('active',TABS[i]===tab));
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+tab).classList.add('active');
  renderCurrentTab();
}
function renderCurrentTab() {
  if(activeTab==='brain')  { renderDump(); }
  if(activeTab==='big3')   renderBig3();
  if(activeTab==='backlog')renderBacklog(currentFilter);
  if(activeTab==='timebox')renderTimeGrid();
  if(activeTab==='review') renderReviews();
